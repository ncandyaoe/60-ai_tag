+def _get_char_style(spans: List[TextSpan], char_index: int) -> tuple[bool, bool]:
+    """根据全局字符索引，找出该字符是否加粗、是否下划线"""
+    curr_len = 0
+    for span in spans:
+        if curr_len <= char_index < curr_len + len(span.text):
+            return span.bold, span.underline
+        curr_len += len(span.text)
+    return False, False
+
