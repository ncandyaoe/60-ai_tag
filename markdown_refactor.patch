+        path = os.path.join(eco_dir, eco_icon_names[i])
+        if not os.path.exists(path):
+            continue
+
+        # 读取图标原始尺寸
+        from PIL import Image as PILImage
+        img = PILImage.open(path)
+        img_w, img_h = img.width, img.height
